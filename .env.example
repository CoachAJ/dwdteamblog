# Local development (SQLite)
DATABASE_PROVIDER="sqlite"
DATABASE_URL="file:./dev.db"

# Production on Netlify (swap to postgresql + Neon/Supabase URL)
# DATABASE_PROVIDER="postgresql"
# DATABASE_URL="postgresql://user:pass@host/dbname?sslmode=require"

ADMIN_PASSWORD="changeme"
AUTH_SECRET="replace-with-a-long-random-secret-string"

# API key for external apps to post directly (Authorization: Bearer <API_KEY>)
API_KEY="replace-with-a-long-random-api-key"

# Your deployed blog URL (used in email links)
NEXT_PUBLIC_BLOG_URL="https://your-blog-url.netlify.app"

# GetResponse integration (optional - send email on publish)
GETRESPONSE_API_KEY="your-getresponse-api-key"
GETRESPONSE_CAMPAIGN_ID="your-campaign-id"

# Daily digest cron (must match GitHub Actions secret)
DIGEST_SECRET="replace-with-a-long-random-string"
